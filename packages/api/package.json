{
  "name": "@moonwell-ai/api",
  "version": "0.1.0",
  "private": true,
  "description": "Moonwell HTTP API on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@moonwell-fi/moonwell-sdk": "0.9.34",
    "hono": "4.12.16",
    "viem": "2.47.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260504.1",
    "@types/node": "22.19.17",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
