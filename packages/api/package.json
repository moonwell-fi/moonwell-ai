{
  "name": "@moonwell-ai/api",
  "version": "0.1.0",
  "private": true,
  "description": "Moonwell HTTP API on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@moonwell-fi/moonwell-sdk": "^0.9.0",
    "hono": "^4.6.0",
    "viem": "^2.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
