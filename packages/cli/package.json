{
  "name": "@moonwell-fi/cli",
  "version": "1.0.0",
  "description": "Agent-first CLI for the Moonwell lending protocol",
  "homepage": "https://agents.moonwell.fi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moonwell-fi/moonwell-ai.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "keywords": [
    "moonwell",
    "defi",
    "lending",
    "base",
    "optimism",
    "compound",
    "agent",
    "cli"
  ],
  "type": "module",
  "bin": {
    "moonwell": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@moonwell-fi/moonwell-sdk": "0.9.34",
    "chalk": "5.6.2",
    "commander": "13.1.0",
    "ora": "8.2.0",
    "viem": "2.47.12"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
