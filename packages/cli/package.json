{
  "name": "@moonwell-fi/cli",
  "version": "1.0.0",
  "description": "Agent-first CLI for the Moonwell lending protocol",
  "homepage": "https://agents.moonwell.fi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moonwell-fi/moonwell-ai.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "keywords": ["moonwell", "defi", "lending", "base", "optimism", "compound", "agent", "cli"],
  "type": "module",
  "bin": {
    "moonwell": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@moonwell-fi/moonwell-sdk": "^0.9.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "viem": "^2.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
