# Defense-in-depth against the TanStack-style npm supply-chain attack class
# (May 2026 incident: 84 malicious @tanstack/* versions executed postinstall code).
#
# Block ALL lifecycle scripts (preinstall/install/postinstall/prepare) globally.
# A malicious dep installed via Renovate, a typo-squat, or a poisoned cache
# cannot execute code just by being installed.
#
# Legitimate native-binary deps live in package.json#lifecycleScriptAllowlist
# and are explicitly enabled by `pnpm run allow-scripts` after install.
ignore-scripts=true
